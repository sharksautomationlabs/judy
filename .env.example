# Copy this file to .env.local and fill in real values.
# On Vercel, add these under Project Settings -> Environment Variables.

# Stripe (required for checkout/payments)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Redis (required on Vercel for blog admin panel to persist posts)
# Create via Vercel Dashboard -> Storage -> Create Database -> Redis
# (Vercel sets REDIS_URL automatically when you connect the store)
# Optional locally: without it, posts are saved to data/blog-posts.json
REDIS_URL=
